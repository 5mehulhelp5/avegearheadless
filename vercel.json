{
    "rewrites": [
        {
            "source": "/magento-api/(.*)",
            "destination": "https://2fc1869dd5.nxcli.io/$1"
        },
        {
            "source": "/graphql",
            "destination": "https://2fc1869dd5.nxcli.io/graphql"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/(.*).(png|jpg|jpeg|gif|webp|avif|svg|ico)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, must-revalidate"
                }
            ]
        },
        {
            "source": "/(.*).(woff|woff2|eot|ttf|otf)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}